# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/app/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
.agents/
.claude/
.continue/
.kiro/
skills-lock.json
.vscode/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev-server.err.log
dev-server.out.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel
.tmp-designs

# typescript
*.tsbuildinfo
next-env.d.ts
vite.config.js
vite.config.d.ts
